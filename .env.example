MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/prepify?retryWrites=true&w=majority
PORT=4001

# Optional. When set, the /v2 route fetches cache misses from Spoonacular
# server-side (Phase 2) so clients never need a key. Unset = pure cache.
SPOONACULAR_API_KEY=

# Optional. Per-IP rate limit on the /v2 route (defaults: 120 requests / 60s).
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
